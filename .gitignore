# Secrets and local configs
*.local.json
*local*.json
secrets.json
.env
.env.*
credentials.json
*.credentials.json

# API keys and tokens
*.key
*.pem
*.crt

# Backup files
*.bak
codex.bak*/
*.tmp
*.temp
*.log

# Python cache
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# MCP local configs
*mcp_config*.json

# Antigravity workspace rules must be versioned so the IDE can activate them.
/.agents/

# Platform auto-generated mirrors (we only track overlays and scripts in git)
platforms/codex/rules/*
!platforms/codex/rules/codex-overlay.md
platforms/codex/skills/
platforms/grok/rules/
platforms/grok/skills/
platforms/antigravity/.agents/rules/*
!platforms/antigravity/.agents/rules/antigravity-overlay.md
platforms/antigravity/.agents/skills/
platforms/antigravity/.agents/workflows/

# Grok live mirror — use ~/.grok/ global only (install-grok-global.sh)
.grok/

# Runtime/test artifacts
dist/
build/
coverage/
test-results/
playwright-report/
output/
downloads/
*.qa.png
*.qa.jpg
*.qa.jpeg
*.qa.webp
*.qa.mp4
*.trace.zip

# One-off scratch scripts should live outside tracked runtime scripts.
scratch/
tmp/
