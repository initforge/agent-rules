{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://initforge.github.io/agent-rules/work-ledger.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_id",
    "status",
    "created_at",
    "updated_at",
    "plan",
    "host_refs",
    "classification",
    "execution_contract",
    "repository",
    "source_history",
    "slices",
    "assignments",
    "receipts",
    "reviews",
    "findings",
    "checkpoints",
    "usage",
    "next_action",
    "active_slices", "model_policy_reasons", "lifecycle_status", "task_status",
    "orchestration_status", "control_plane_exceptions", "proof_cache", "telemetry_events"
  ],
  "properties": {
    "schema_version": { "const": 4 },
    "work_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,79}$" },
    "status": {
      "enum": ["planned", "running", "blocked", "needs-replan", "passed", "partial", "rolled-back"]
    },
    "lifecycle_status": { "enum": ["planned", "running", "blocked", "needs-replan", "passed", "partial", "rolled-back"] },
    "task_status": { "enum": ["open", "blocked", "passed", "partial", "cancelled"] },
    "orchestration_status": { "enum": ["healthy", "recovering", "degraded", "exception", "unverified"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "plan": { "$ref": "#/$defs/plan" },
    "host_refs": { "$ref": "#/$defs/hostRefs" },
    "active_slices": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shape", "ledger", "strategy", "review_required", "reasons"],
      "properties": {
        "shape": { "enum": ["small", "medium", "large", "resumable"] },
        "ledger": { "enum": ["off", "auto", "required"] },
        "strategy": { "enum": ["single-agent", "delegated", "parallel"] },
        "review_required": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "execution_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "max_active_agents_including_main",
        "max_delegation_depth",
        "effort_cap",
        "authorized_final_actions",
        "execute_authorization", "run_id", "main_direct_policy"
      ],
      "properties": {
        "mode": { "const": "automatic" },
        "max_active_agents_including_main": { "type": "integer", "minimum": 1, "maximum": 16 },
        "max_delegation_depth": { "type": "integer", "minimum": 0, "maximum": 2 },
        "effort_cap": { "enum": ["low", "medium", "high"] },
        "authorized_final_actions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["edit", "commit", "push", "deploy", "external-write"] }
        },
        "execute_authorization": { "$ref": "#/$defs/executeAuthorization" },
        "run_id": { "type": "string", "minLength": 1 },
        "main_direct_policy": { "$ref": "#/$defs/mainDirectPolicy" }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "branch", "baseline_commit"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "baseline_commit": { "type": "string", "minLength": 1 }
      }
    },
    "source_history": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slice" }
    },
    "assignments": {
      "type": "array",
      "items": { "$ref": "#/$defs/assignment" }
    },
    "receipts": {
      "type": "array",
      "items": { "$ref": "#/$defs/receipt" }
    },
    "reviews": {
      "type": "array",
      "items": { "$ref": "#/$defs/review" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "checkpoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/checkpoint" }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "reasoning_tokens",
        "agent_runs",
        "tool_calls",
        "records"
      ],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "reasoning_tokens": { "type": "integer", "minimum": 0 },
        "agent_runs": { "type": "integer", "minimum": 0 },
        "tool_calls": { "type": "integer", "minimum": 0 },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/usageRecord" }
        }
      }
    },
    "next_action": { "type": "string" },
    "model_policy_reasons": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "control_plane_exceptions": { "type": "array", "items": { "$ref": "#/$defs/controlPlaneException" } },
    "proof_cache": { "type": "array", "items": { "$ref": "#/$defs/proofCache" } }
    ,"telemetry_events": { "type": "array", "items": { "$ref": "#/$defs/telemetryEvent" } }
  },
  "$defs": {
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "sha256", "identity"],
      "properties": {
        "ref": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "identity": { "type": "string", "minLength": 1 }
      }
    },
    "hostRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "task_ref", "session_ref"],
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "task_ref": { "type": "string" },
        "session_ref": { "type": "string" }
      }
    },
    "executeAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorized", "recorded_at", "source", "actions"],
      "properties": {
        "authorized": { "const": true },
        "recorded_at": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "minLength": 1 },
        "actions": { "type": "array", "uniqueItems": true, "items": { "enum": ["edit", "commit", "push", "deploy", "external-write"] } }
      }
    },
    "modelEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_model", "requested_effort", "resolved_model", "resolved_effort", "observed_model", "observed_effort", "status", "fallback_reason", "main_direct_exception_reason"],
      "properties": {
        "requested_model": { "type": "string", "minLength": 1 },
        "requested_effort": { "enum": ["low", "medium", "high"] },
        "resolved_model": { "type": "string", "minLength": 1 },
        "resolved_effort": { "enum": ["low", "medium", "high"] },
        "observed_model": { "type": ["string", "null"] },
        "observed_effort": { "type": ["string", "null"] },
        "status": { "enum": ["observed", "unobserved", "fallback"] },
        "fallback_reason": { "type": "string" },
        "main_direct_exception_reason": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "summary", "captured_at", "redacted", "slice_ids"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z]+-[0-9]{3}$" },
        "kind": { "enum": ["original", "decision", "injection", "discovery"] },
        "summary": { "type": "string", "minLength": 1 },
        "verbatim_excerpt": { "type": "string" },
        "captured_at": { "type": "string", "format": "date-time" },
        "redacted": { "type": "boolean" },
        "slice_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "claim",
        "status",
        "proof_required",
        "proof_profile",
        "required_proof_kinds",
        "required_dimensions",
        "receipt_ids", "proof_epoch", "full_gate_fingerprint"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^AC[0-9]+$" },
        "claim": { "type": "string", "minLength": 1 },
        "status": { "enum": ["open", "passed", "failed", "blocked"] },
        "proof_required": { "type": "boolean" },
        "proof_profile": { "type": "string", "minLength": 1 },
        "required_proof_kinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "static", "diff", "build", "unit", "integration", "api", "e2e",
              "browser", "performance", "security", "manual", "artifact"
            ]
          }
        },
        "required_dimensions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "receipt_ids": { "type": "array", "items": { "type": "string" } },
        "proof_epoch": { "type": "integer", "minimum": 0 },
        "full_gate_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "slice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "name", "status", "depends_on", "required", "review_required", "acceptance"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["planned", "ready", "running", "review", "passed", "blocked", "needs-replan", "rolled-back"]
        },
        "depends_on": { "type": "array", "items": { "type": "string" } },
        "required": { "type": "boolean" },
        "review_required": { "type": "boolean" },
        "acceptance": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/acceptance" } }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slice_id",
        "agent",
        "role",
        "model_class",
        "model",
        "effort",
        "source_ids",
        "write_paths",
        "context_paths",
        "forbidden_paths",
        "acceptance_ids",
        "status",
        "model_evidence", "mission", "actor_session", "allowed_tool_classes", "capsule_hash",
        "receipt_budget", "recovery_attempts", "actor_telemetry_refs", "ack_status"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "slice_id": { "type": "string", "minLength": 1 },
        "agent": { "type": "string", "minLength": 1 },
        "role": { "enum": ["researcher", "mechanical-executor", "executor", "reviewer", "specialist", "main"] },
        "model_class": { "enum": ["economy", "standard", "expert"] },
        "model": { "type": "string", "minLength": 1 },
        "effort": { "enum": ["low", "medium", "high"] },
        "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "write_paths": { "type": "array", "items": { "type": "string" } },
        "context_paths": { "type": "array", "items": { "type": "string" } },
        "forbidden_paths": { "type": "array", "items": { "type": "string" } },
        "acceptance_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "status": { "enum": ["ready", "running", "done", "blocked", "cancelled"] },
        "model_evidence": { "$ref": "#/$defs/modelEvidence" },
        "completed_at": { "type": "string", "format": "date-time" },
        "host_attestation_ref": { "type": "string", "minLength": 1 },
        "mission": { "type": "string", "minLength": 1 },
        "actor_session": { "type": "string", "minLength": 1 },
        "allowed_tool_classes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["read", "edit", "test", "shell", "browser", "network", "git", "external-write"] } },
        "capsule_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "receipt_budget": { "type": "integer", "minimum": 1, "maximum": 100 },
        "recovery_attempts": { "type": "array", "items": { "$ref": "#/$defs/recoveryAttempt" } },
        "actor_telemetry_refs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
        ,"ack_status": { "enum": ["pending", "acknowledged", "legacy-implicit"] }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slice_id",
        "acceptance_id",
        "claim",
        "status",
        "expected",
        "observed",
        "environment",
        "agent",
        "model",
        "effort",
        "captured_at",
        "claim_hash",
        "contract_hash",
        "provenance",
        "proof_kind",
        "dimensions",
        "command_hash",
        "output_hash",
        "exit_code",
        "expected_exit_code",
        "artifact_evidence",
        "verifier",
        "model_evidence", "proof_epoch", "full_gate_fingerprint", "actor_telemetry_ref"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "slice_id": { "type": "string", "minLength": 1 },
        "acceptance_id": { "type": "string", "minLength": 1 },
        "claim": { "type": "string", "minLength": 1 },
        "claim_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "contract_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
        "provenance": { "enum": ["runner", "external-verifier"] },
        "proof_kind": {
          "enum": [
            "static", "diff", "build", "unit", "integration", "api", "e2e",
            "browser", "performance", "security", "manual", "artifact"
          ]
        },
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "command": { "type": "string" },
        "command_hash": {
          "oneOf": [
            { "const": "" },
            { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          ]
        },
        "expected": { "type": "string", "minLength": 1 },
        "observed": { "type": "string", "minLength": 1 },
        "environment": { "type": "string", "minLength": 1 },
        "output_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "exit_code": { "type": ["integer", "null"] },
        "expected_exit_code": { "type": ["integer", "null"] },
        "artifact_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactEvidence" }
        },
        "verifier": { "type": "string", "minLength": 1 },
        "agent": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "effort": { "enum": ["low", "medium", "high"] },
        "captured_at": { "type": "string", "format": "date-time" },
        "model_evidence": { "$ref": "#/$defs/modelEvidence" },
        "proof_epoch": { "type": "integer", "minimum": 0 },
        "full_gate_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "actor_telemetry_ref": { "type": "string" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slice_id", "severity", "summary", "status", "reviewer", "created_at", "owner_assignment_id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "slice_id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "summary": { "type": "string", "minLength": 1 },
        "status": { "enum": ["open", "resolved", "accepted"] },
        "reviewer": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "resolution": { "type": "string" },
        "resolved_at": { "type": "string", "format": "date-time" },
        "owner_assignment_id": { "type": "string" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slice_id",
        "reviewer",
        "status",
        "scope",
        "observed",
        "receipt_ids",
        "receipt_hashes",
        "model",
        "effort",
        "created_at",
        "model_evidence"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "slice_id": { "type": "string", "minLength": 1 },
        "reviewer": { "type": "string", "minLength": 1 },
        "status": { "enum": ["PASS", "FAIL"] },
        "scope": { "type": "string", "minLength": 1 },
        "observed": { "type": "string", "minLength": 1 },
        "receipt_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "receipt_hashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "model": { "type": "string", "minLength": 1 },
        "effort": { "enum": ["low", "medium", "high"] },
        "created_at": { "type": "string", "format": "date-time" },
        "model_evidence": { "$ref": "#/$defs/modelEvidence" }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slice_id", "commit", "summary", "next_action", "created_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "slice_id": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "artifactEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes", "modified_at"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "modified_at": { "type": "string", "format": "date-time" }
      }
    },
    "usageRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "captured_at",
        "actor",
        "assignment_id",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "reasoning_tokens",
        "agent_runs",
        "tool_calls"
      ],
      "properties": {
        "captured_at": { "type": "string", "format": "date-time" },
        "actor": { "type": "string", "minLength": 1 },
        "assignment_id": { "type": ["string", "null"] },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "reasoning_tokens": { "type": "integer", "minimum": 0 },
        "agent_runs": { "type": "integer", "minimum": 0 },
        "tool_calls": { "type": "integer", "minimum": 0 }
        ,"actor_session": { "type": "string", "minLength": 1 }
        ,"actor_telemetry_ref": { "type": "string" }
      }
    },
    "mainDirectPolicy": {
      "type": "object", "additionalProperties": false, "required": ["allowed", "allowed_tool_classes"],
      "properties": { "allowed": { "type": "boolean" }, "allowed_tool_classes": { "type": "array", "uniqueItems": true, "items": { "enum": ["read", "edit", "test", "shell", "browser", "network", "git", "external-write"] } } }
    },
    "recoveryAttempt": {
      "type": "object", "additionalProperties": false, "required": ["attempt", "reason", "status", "recorded_at"],
      "properties": { "attempt": { "type": "integer", "minimum": 1 }, "reason": { "type": "string", "minLength": 1 }, "status": { "enum": ["started", "recovered", "failed"] }, "recorded_at": { "type": "string", "format": "date-time" }, "actor_telemetry_ref": { "type": "string" } }
    },
    "controlPlaneException": {
      "type": "object", "additionalProperties": false, "required": ["kind", "scope", "reason", "recorded_at"],
      "properties": { "kind": { "const": "CONTROL_PLANE_EXCEPTION" }, "scope": { "enum": ["orchestration", "main-direct", "host-telemetry"] }, "reason": { "type": "string", "minLength": 1 }, "recorded_at": { "type": "string", "format": "date-time" }, "assignment_id": { "type": "string" }, "actor_telemetry_ref": { "type": "string" } }
    },
    "proofCache": {
      "type": "object", "additionalProperties": false, "required": ["cache_key", "run_id", "slice_id", "acceptance_id", "proof_epoch", "full_gate_fingerprint", "receipt_id"],
      "properties": { "cache_key": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "run_id": { "type": "string", "minLength": 1 }, "slice_id": { "type": "string", "minLength": 1 }, "acceptance_id": { "type": "string", "minLength": 1 }, "proof_epoch": { "type": "integer", "minimum": 0 }, "full_gate_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "receipt_id": { "type": "string", "minLength": 1 } }
    },
    "telemetryEvent": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "platform", "event", "session_id", "actor", "assignment_id", "tool", "tool_class", "timestamp", "outcome", "event_id"],
      "properties": {
        "schema_version": { "const": 1 }, "platform": { "type": "string", "minLength": 1 }, "event": { "type": "string", "minLength": 1 },
        "session_id": { "type": "string", "minLength": 1 }, "actor": { "enum": ["main", "worker", "unknown"] }, "assignment_id": { "type": "string", "minLength": 1 },
        "tool": { "type": "string", "minLength": 1 }, "tool_class": { "type": "string", "minLength": 1 }, "timestamp": { "type": "string", "format": "date-time" },
        "outcome": { "type": "string", "minLength": 1 }, "event_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
