    { "id": "unit-test", "prompt": "Chạy unit test cho service", "must_not_load": ["browser-qa"] },
    { "id": "manual-browser", "prompt": "Manual browser QA click-through", "must_load": ["qa-skills", "browser-qa"] },
    { "id": "harness", "prompt": "Tinh gọn rules và skills của agent-rules", "must_load": ["context-evolution-protocol"], "must_not_load": ["docs-style", "researcher"] },
    { "id": "long-plan", "prompt": "Lập kế hoạch nhiều phase cho harness", "must_load": ["plan-and-handoff"] },
    { "id": "project-setup", "prompt": "Cài context cho project 5fedu", "must_load": ["5fedu-project"], "must_not_load": ["5fedu-module-parity", "browser-qa"] },
    { "id": "5fedu-database", "prompt": "Kiểm tra migration RLS và schema int8", "must_load": ["database-domain"], "must_not_load": ["5fedu-module-parity", "frontend-architect"] },
