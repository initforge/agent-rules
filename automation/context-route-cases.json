    { "id": "generic-project-domain", "prompt": "Sửa quy tắc nghiệp vụ của project không dùng 5fedu", "must_load": ["project-router"], "must_not_load": ["5fedu-project", "5fedu-module-parity"] },
    { "id": "export-reference", "prompt": "Kiểm tra xuất Excel/PDF tiếng Việt", "must_load": ["export-reference"], "must_not_load": ["browser-qa", "5fedu-module-parity"] },
    { "id": "metadata-output", "prompt": "Giải thích tiến độ xử lý cho người dùng", "must_not_show": ["Skill scan", "Skill activated", "Classification", "Lane", "Friction: none", "Ledger:"] }
