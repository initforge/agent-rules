{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://initforge.github.io/agent-rules/live-result.schema.json",
  "type": "object",
  "required": ["run_id", "case_id", "variant", "evidence_kind", "platform", "model", "reasoning_effort", "tools_available", "started_at", "finished_at", "outcome", "scores", "evidence", "owner_correction", "friction"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "case_id": { "type": "string", "minLength": 1 },
    "variant": { "enum": ["baseline", "core", "full"] },
    "evidence_kind": { "enum": ["empirical", "synthetic"] },
    "platform": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "model_version": { "type": "string" },
    "reasoning_effort": { "type": "string", "minLength": 1 },
    "tools_available": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "termination": { "enum": ["completed", "timeout", "cancelled", "runner_error"] },
    "outcome": { "enum": ["PASS", "PARTIAL", "BLOCKED", "FAIL", "NOT_RUN"] },
    "scores": {
      "type": "object",
      "required": ["scope", "correctness", "safety", "verification", "communication"],
      "properties": {
        "scope": { "type": "integer", "minimum": 0, "maximum": 4 },
        "correctness": { "type": "integer", "minimum": 0, "maximum": 4 },
        "safety": { "type": "integer", "minimum": 0, "maximum": 4 },
        "verification": { "type": "integer", "minimum": 0, "maximum": 4 },
        "communication": { "type": "integer", "minimum": 0, "maximum": 4 }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "label", "status", "ref"],
        "properties": {
          "type": { "enum": ["command", "artifact", "review", "runtime"] },
          "kind": { "type": "string", "minLength": 1 },
          "dimensions": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "label": { "type": "string", "minLength": 1 },
          "status": { "enum": ["PASS", "FAIL", "SKIP"] },
          "ref": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "owner_correction": { "type": "boolean" },
    "friction": { "type": "array", "items": { "type": "string" } },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "input_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Main-agent input only; excludes subagents." },
    "cached_input_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Cached portion of main-agent input." },
    "uncached_input_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Uncached portion of main-agent input." },
    "output_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Main-agent output only; excludes subagents." },
    "reasoning_output_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Main-agent reasoning output only." },
    "tool_calls": { "type": ["integer", "null"], "minimum": 0 },
    "turn_count": { "type": ["integer", "null"], "minimum": 0 },
    "tool_output_chars": { "type": ["integer", "null"], "minimum": 0 },
    "subagent_input_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Sum across subagents only." },
    "subagent_cached_input_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Cached portion of subagent input." },
    "subagent_uncached_input_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Uncached portion of subagent input." },
    "subagent_output_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Sum across subagents only." },
    "subagent_reasoning_output_tokens": { "type": ["integer", "null"], "minimum": 0, "description": "Sum of subagent reasoning output." },
    "claim_profile": { "type": "string", "minLength": 1 },
    "proof_dimensions": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "max_input_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
