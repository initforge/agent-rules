{
  "version": 1,
  "mode": "active",
  "default_profile": "normal",
  "profiles": {
    "tiny": { "checkpoint": false },
    "normal": {
      "tool_calls": 20,
      "tool_output_chars": 60000,
      "repeat_after_tool_calls": 10,
