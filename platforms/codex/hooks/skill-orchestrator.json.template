{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "commandWindows": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "commandWindows": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "run_terminal_command|shell_command|Bash|Shell",
        "hooks": [
          {
            "type": "command",
            "command": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "commandWindows": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "timeout": 8
          }
        ]
      },
      {
        "matcher": "search_replace|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "commandWindows": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "run_terminal_command|shell_command|Bash|Shell|search_replace|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "commandWindows": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "timeout": 8
          }
        ]
      },
      {
        "matcher": "search_replace|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "__CODEX_HOME__/scripts/audit-on-edit.sh",
            "commandWindows": "bash \"__CODEX_HOME__/scripts/audit-on-edit.sh\"",
            "timeout": 6
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "commandWindows": "\"__PYTHON__\" \"__CODEX_HOME__/scripts/skill-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
