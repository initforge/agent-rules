{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_HOME}/scripts/skill-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_HOME}/scripts/skill-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "run_terminal_command|Bash|Shell",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_HOME}/scripts/skill-gate.sh",
            "timeout": 8
          }
        ]
      },
      {
        "matcher": "search_replace|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_HOME}/scripts/skill-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "run_terminal_command|Bash|Shell|search_replace|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_HOME}/scripts/skill-gate.sh",
            "timeout": 8
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_HOME}/scripts/skill-gate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}